# DiscountBazaar Backend — Local Environment
# Copy to .env and fill in real values. Do NOT commit .env.

# HTTP
PORT=4000
NODE_ENV=development

# MongoDB (required at runtime — project architecture mandates Mongoose/MongoDB)
MONGODB_URI=mongodb://127.0.0.1:27017/discountbazaar

# Redis (required at runtime for BullMQ squad/voting job queues)
REDIS_URL=redis://127.0.0.1:6379

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Safepay (leave empty until escrow integration phase)
SAFEPAY_API_KEY=
# Required at boot. Used to HMAC-verify incoming Safepay webhooks.
SAFEPAY_WEBHOOK_SECRET=replace-with-a-long-random-string

# Required at boot. Shared secret courier partners send in the
# `x-courier-secret` header when posting logistics updates to
# POST /api/orders/webhook.
COURIER_WEBHOOK_SECRET=replace-with-a-long-random-string

# Frontend (Next.js) — server-side base URL for internal API calls.
# No localhost fallback: must be set explicitly.
BACKEND_INTERNAL_URL=http://127.0.0.1:4000
